# PyAgentForge 环境配置示例
# 复制此文件为 .env 并填写实际值

# ============ LLM 提供商配置 ============
# Anthropic (Claude) API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (GPT) API
OPENAI_API_KEY=your-openai-api-key-here

# 默认使用的模型
DEFAULT_MODEL=claude-sonnet-4-20250514

# ============ 上下文压缩配置 ============
# 是否启用上下文压缩
COMPACTION_ENABLED=true
# 压缩时预留的 tokens
COMPACTION_RESERVE_TOKENS=8000
# 保留最近消息的 tokens
COMPACTION_KEEP_RECENT_TOKENS=4000
# 触发压缩的阈值 (0.5-1.0)
COMPACTION_THRESHOLD=0.8
# 最大上下文 tokens
MAX_CONTEXT_TOKENS=200000

# ============ 思考级别配置 ============
# 默认思考级别 (off/minimal/low/medium/high/xhigh)
DEFAULT_THINKING_LEVEL=off
# 思考 token 预算 (null 表示自动)
# THINKING_BUDGET_TOKENS=4096

# ============ 服务配置 ============
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ============ 数据库配置 ============
# SQLite (默认)
DATABASE_URL=sqlite+aiosqlite:///./data/pyagentforge.db

# PostgreSQL (可选)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/pyagentforge

# ============ 安全配置 ============
# JWT 密钥 (生产环境请使用强密钥)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============ 存储配置 ============
# 技能目录
SKILLS_DIR=./data/skills

# 日志级别
LOG_LEVEL=INFO
