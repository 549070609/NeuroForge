# GLM Provider 配置

# 智谱 AI API Key (从 https://open.bigmodel.cn/ 获取)
GLM_API_KEY=your_glm_api_key_here

# 默认模型 (glm-4-flash, glm-4-plus, glm-4-air, glm-4-long, glm-5)
GLM_MODEL=glm-5

# API 端点地址
# - Coding Plan 专用 (Anthropic 兼容): https://api.z.ai/api/anthropic
# - Coding Plan 专用 (OpenAI 兼容): https://api.z.ai/api/coding/paas/v4
# - 通用 API: https://open.bigmodel.cn/api/paas/v4
GLM_BASE_URL=https://api.z.ai/api/anthropic

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8100
