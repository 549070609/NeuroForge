{
  "$schema": "./llm_config_schema.json",
  "_comment": "模型级 LLM 配置示例：不再定义内置厂商，仅保留协议格式、URL、模型名、密钥等必要参数",
  "default_model": "custom-openai-like",
  "max_tokens": 4096,
  "temperature": 1.0,
  "models": {
    "custom-openai-like": {
      "id": "custom-openai-like",
      "name": "Custom OpenAI-Compatible Model",
      "provider": "my-provider",
      "api_type": "openai-completions",
      "model_name": "model-name-on-server",
      "base_url": "https://api.example.com/v1",
      "api_key_env": "MY_LLM_API_KEY",
      "headers": {
        "X-Workspace": "demo"
      },
      "timeout": 120,
      "supports_tools": true,
      "supports_streaming": true,
      "supports_vision": false,
      "context_window": 128000,
      "max_output_tokens": 4096,
      "extra": {}
    },
    "custom-anthropic-like": {
      "id": "custom-anthropic-like",
      "name": "Custom Messages-Compatible Model",
      "provider": "another-provider",
      "api_type": "anthropic-messages",
      "model_name": "messages-model-name",
      "base_url": "https://api.example.com",
      "api_key_env": "ANOTHER_LLM_API_KEY",
      "timeout": 120,
      "supports_tools": true,
      "supports_streaming": true,
      "supports_vision": true,
      "context_window": 200000,
      "max_output_tokens": 8192,
      "extra": {}
    }
  }
}
