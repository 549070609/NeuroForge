{
  "default_model": "default",
  "max_tokens": 4096,
  "temperature": 1.0,
  "providers": {
    "custom": {
      "enabled": true,
      "api_key": null,
      "api_key_env": "CUSTOM_API_KEY",
      "base_url": "https://your-llm-gateway.example/v1",
      "timeout": 120,
      "max_retries": 3,
      "extra": {
        "headers": {
          "X-Provider": "custom"
        }
      }
    }
  },
  "models": {
    "default": {
      "id": "default",
      "name": "Default Model",
      "provider": "custom",
      "api_type": "openai-completions",
      "supports_vision": true,
      "supports_tools": true,
      "supports_streaming": true,
      "context_window": 128000,
      "max_output_tokens": 8192,
      "cost_input": 0.0,
      "cost_output": 0.0,
      "cost_cache_read": 0.0,
      "cost_cache_write": 0.0,
      "api_key": null,
      "api_key_env": "CUSTOM_API_KEY",
      "base_url": "https://your-llm-gateway.example/v1",
      "extra": {
        "headers": {
          "X-Model-Router": "default"
        }
      }
    }
  }
}
