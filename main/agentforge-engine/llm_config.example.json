{
  "_comment": "LLM 配置模板 - 复制此文件为 llm_config.json 并填入您的配置",
  "_usage": "设置环境变量 LLM_CONFIG_PATH 指向您的配置文件路径",

  "default_model": "default",
  "max_tokens": 4096,
  "temperature": 1.0,

  "providers": {
    "custom": {
      "enabled": true,
      "api_key_env": "CUSTOM_API_KEY",
      "base_url": "https://your-llm-gateway.example/v1",
      "timeout": 120,
      "extra": {
        "headers": {
          "X-Provider": "custom"
        }
      }
    }
  },

  "models": {
    "default": {
      "id": "default",
      "name": "Default Model",
      "provider": "custom",
      "api_type": "openai-completions",
      "supports_vision": true,
      "context_window": 128000,
      "max_output_tokens": 8192,
      "base_url": "https://your-llm-gateway.example/v1",
      "api_key_env": "CUSTOM_API_KEY",
      "extra": {
        "headers": {
          "X-Model-Router": "default"
        }
      }
    }
  }
}
