{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./llm_config_schema.json",
  "title": "NeuroForge LLM Config",
  "type": "object",
  "required": ["models"],
  "properties": {
    "default_model": {
      "type": "string",
      "description": "默认模型 ID"
    },
    "max_tokens": {
      "type": "integer",
      "minimum": 1,
      "description": "默认最大输出 Token"
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2,
      "description": "默认温度"
    },
    "models": {
      "type": "object",
      "description": "模型配置映射",
      "additionalProperties": {
        "$ref": "#/$defs/model"
      }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "required": ["id", "name", "provider", "api_type"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "provider": {
          "type": "string",
          "description": "供应商标识，仅用于展示与分组"
        },
        "api_type": {
          "type": "string",
          "enum": [
            "anthropic-messages",
            "openai-completions",
            "openai-responses",
            "google-generative-ai",
            "bedrock-converse-stream",
            "custom"
          ]
        },
        "model_name": { "type": ["string", "null"] },
        "supports_vision": { "type": "boolean" },
        "supports_tools": { "type": "boolean" },
        "supports_streaming": { "type": "boolean" },
        "context_window": { "type": "integer", "minimum": 1 },
        "max_output_tokens": { "type": "integer", "minimum": 1 },
        "cost_input": { "type": "number" },
        "cost_output": { "type": "number" },
        "cost_cache_read": { "type": "number" },
        "cost_cache_write": { "type": "number" },
        "api_key": { "type": ["string", "null"] },
        "api_key_env": { "type": ["string", "null"] },
        "base_url": { "type": ["string", "null"] },
        "timeout": { "type": "integer", "minimum": 1 },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "extra": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
